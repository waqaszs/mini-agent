{
  "name": "mini-agent",
  "version": "0.0.1",
  "private": true,
  "description": "A mini coding agent — a Node.js CLI that implements the open Agent Skills specification, powered by Claude's Sonnet model.",
  "type": "module",
  "bin": {
    "mini-agent": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --clean --target node18",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "eval": "tsx scripts/eval.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@clack/prompts": "^1.6.0",
    "boxen": "^8.0.1",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
